DATABASE_URL=postgresql+asyncpg://user:password@db.supabase.co:5432/postgres
SECRET_KEY=your-super-secret-key-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# LOTPLOT 28 — Supabase Auth (HS256)
# Dashboard Supabase → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...           # anon public key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # service_role (script migration ONLY)
SUPABASE_JWT_SECRET=                       # JWT secret HS256 (différent des keys ci-dessus)

RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@logeo.ca
ADMIN_EMAIL=admin@logeo.ca
# Optionnel : si défini, injecté en Reply-To sur tous les emails sortants.
# Permet de recevoir les replies dans une boîte perso sans monter un mailbox
# sur logeo.ca. Laisser vide = pas de header Reply-To.
REPLY_TO_EMAIL=

FRONTEND_URL=https://logeo.ca
BACKEND_URL=https://api.logeo.ca

DEFAULT_AUCTION_HOURS=240

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Frais Logeo
FEE_PERCENT=1.0
DEPOSIT_PERCENT_OF_FEE=25.0
DEPOSIT_MINIMUM_CAD=2500

DEPOSIT_RETRY_HOURS=48
DUE_DILIGENCE_HOURS=24

# Supabase Storage (laisser STORAGE_BACKEND=local en dev sans buckets)
STORAGE_BACKEND=local
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET_DEALS=deals
SUPABASE_BUCKET_DOCUMENTS=documents
SUPABASE_BUCKET_PROFILES=profiles
SIGNED_URL_TTL_SECONDS=3600

# Enchère proxy
BID_MIN_INCREMENT=10000
ANTI_SNIPE_WINDOW_MINUTES=10
ANTI_SNIPE_EXTENSION_MINUTES=10
